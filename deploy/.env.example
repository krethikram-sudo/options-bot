# Copy to ../.env (repo root) and fill in. Only CONSOLE_SECRET is required.

# Required: signs session cookies. Generate with: openssl rand -hex 32
CONSOLE_SECRET=

# Public URL of the console (used for links + Stripe redirects). Behind HTTPS in prod.
CONSOLE_BASE_URL=http://localhost:8700
CONSOLE_SECURE_COOKIES=0          # set to 1 when served over HTTPS

# Optional: Stripe usage-based billing (20% of savings). Leave blank to record plans
# locally without charging (the product still works end-to-end).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Optional: transactional email (password resets, invites, alerts). Leave blank to log them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ModelPilot <no-reply@modelpilot.app>

# Optional behavior
CONSOLE_AUTOAPPROVE=             # 1 to auto-approve high-confidence floor proposals
CONSOLE_DIGEST_HOURS=0           # >0 to email a pending-review digest every N hours
