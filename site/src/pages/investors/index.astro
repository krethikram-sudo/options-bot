---
const repoBase = "https://github.com/krethikram-sudo/options-bot/blob/main/skydock";
// SHA-256 hash of the access password. Default: "skydock-investor-2026"
// To change: compute new hash via:  echo -n "your-new-password" | shasum -a 256
const PASSWORD_HASH = "81a8ea8f660c824c8eda9e56c1e49a02389bb3cbd330ea9b51d38eb8db2fa123";
const docs = [
  {
    section: "V2 strategic narrative (current)",
    description: "The V2 architecture: fixed-point capture + curation-as-product + validation-positioning. Replaces V1 mobile-dock per May 2026 pivot.",
    items: [
      { name: "V2 thesis", file: "SKYDOCK_V2_THESIS.md", desc: "The V2 strategic pivot. Why V1 mobile-dock died on unit economics and category positioning. Fixed-point capture + curation moat + safety-team positioning." },
      { name: "PR-FAQ (V2 PITCH.md)", file: "PITCH.md", desc: "Amazon-style PR-FAQ rewritten against V2 architecture. The full investor narrative — closed-loop validation problem, library subscription product, fixed-point unit economics, $2.2M raise. Q27 corrects V1's incorrect Remote ID exemption claim." },
      { name: "V2 execution plan", file: "V2_EXECUTION_PLAN.md", desc: "End-to-end V2 operational plan: now → pre-seed → 18mo → seed. Site deployment sequence (Model A/B/C), curation pipeline build, BVLOS waiver timing, hiring weighted toward engineering + GTM." },
      { name: "V2 financial model", file: "V2_FINANCIAL_MODEL.md", desc: "V2 unit economics + monthly burn + cumulative cash. $2.2M raise, $2/scenario delivered cost, library subscription pricing $100K-$500K/yr, CFP M18-20, end-M18 cash $600K." },
    ],
  },
  {
    section: "V2 customer discovery (current)",
    description: "V2 outreach refocused on AV safety teams + OEM regulatory safety officers + validation-platform channel partners.",
    items: [
      { name: "V2 discovery plan", file: "V2_DISCOVERY_PLAN.md", desc: "6-8 week V2 discovery + closed-loop pilot Phase 0 acquisition plan. 18 named target accounts across Tier 1A (AV safety teams), 1B (OEM regulatory safety), and 2 (channel partners). Conversation guide built around safety case workflow probes." },
      { name: "V2 outreach scripts", file: "V2_OUTREACH_SCRIPTS.md", desc: "4 outreach variants (AV safety team / OEM regulatory / channel partner / warm intro). Pre-built hooks for Waymo, Cruise, Aurora, GM, Foretify. Phase 0 closed-loop pilot conversion mechanic baked into the ask." },
    ],
    note: "CONTACTS.md, WARM_INTRO_TEMPLATES.md, and the V1 OUTREACH_SCRIPTS.md / DISCOVERY_PLAN.md (now marked stale) contain named contacts — available on request via email, not linked here for privacy.",
  },
  {
    section: "Supporting research + evidence",
    description: "Domain research, model performance evidence, competitive landscape, regulatory framework. Largely unchanged by V1→V2 pivot since the underlying domain thesis (aerial BEV solves long-tail / validation) survives.",
    items: [
      { name: "Data value + long-tail research", file: "DATA_VALUE_AND_LONGTAIL_RESEARCH.md", desc: "Deep research on long-tail identification methodology + customer evaluation criteria. Underpins the V2 curation pipeline (criticality, epistemic uncertainty, corpus frequency, interaction density, taxonomy match)." },
      { name: "AV training data research", file: "AV_DATA_VALUE_RESEARCH.md", desc: "Deep research on AV training pipelines. Identifies levelXdata as commercial precedent for V2 fixed-point architecture. Refines thesis." },
      { name: "Model performance evidence", file: "MODEL_PERFORMANCE_EVIDENCE.md", desc: "Peer-reviewed numbers backing aerial BEV model-performance claims. RMSE −64% on highD, +50% hard-case (RoboTron-Sim ICCV 2025), −67% collision rate from long-tail curation." },
      { name: "Value quantification", file: "VALUE_QUANTIFICATION.md", desc: "Customer ROI math. Cost-to-replicate analysis. Sensitivity analysis. Some V1 inputs need V2 refresh (subscription pricing vs per-scenario) but methodology survives." },
      { name: "Competitive graveyard", file: "COMPETITIVE_GRAVEYARD.md", desc: "10 adjacent companies that tried this and failed. PrecisionHawk ($136M raised, bankruptcy), Workhorse HorseFly, SkyDrop, Mighty AI, Civil Maps. Patterns of failure + how Skydock differs." },
      { name: "Regulatory + permits", file: "REGULATORY_PERMITS.md", desc: "FAA Part 107 + tethered ops + BVLOS waiver path. California Civil Code §1708.8 + CCPA + AB 856 privacy. Surfaces and corrects the V1 sub-250g Remote ID exemption error." },
      { name: "Equity projection", file: "EQUITY_PROJECTION.md", desc: "Cap table evolution: incorporation → pre-seed → seed → Series A/B. Founder retention scenarios. V2-compatible (similar dilution, mostly unchanged)." },
      { name: "Thesis review", file: "THESIS_REVIEW.md", desc: "Self-critique of the original thesis. What changed after customer discovery." },
      { name: "Research log", file: "RESEARCH_LOG.md", desc: "Running notes from customer discovery, competitive scans, and industry conversations." },
    ],
  },
  {
    section: "Historical V1 artifacts",
    description: "V1 mobile-dock architecture documents. Kept for historical context and methodology audit trails. The V2 docs above supersede these for any current decision.",
    items: [
      { name: "V1 PR-FAQ (in git history)", file: "../commits/main/skydock/PITCH.md", desc: "The V1 PR-FAQ as of pre-V2-pivot is preserved in git history. Current PITCH.md is the V2 rewrite." },
      { name: "V1 execution plan (stale)", file: "EXECUTION_PLAN.md", desc: "V1 mobile-dock 18-month operating plan. 6-vehicle Bay Area fleet. Hiring weighted toward operator-drivers. Superseded by V2 execution plan." },
      { name: "V1 raise sizing (stale)", file: "RAISE_SIZING.md", desc: "V1 raise sizing analysis — $2.0M based on audited V1 cost model. Superseded by V2 financial model ($2.2M)." },
      { name: "V1 cost model audit (stale)", file: "COST_MODEL_AUDIT.md", desc: "V1 cost audit that surfaced the ~3× undercount in PR-FAQ Q17. Methodology survives; V1-specific numbers do not. V2 unit economics in V2_FINANCIAL_MODEL.md." },
      { name: "V1 assumptions + profitability (stale)", file: "ASSUMPTIONS_AND_PROFITABILITY.md", desc: "V1 assumption audit + profitability-vs-seed timing for V1 architecture. Useful for assumption-audit methodology. V2 has different assumptions." },
      { name: "V1 discovery plan (stale)", file: "DISCOVERY_PLAN.md", desc: "V1 3-thesis parallel discovery plan against perception-team decision-makers. V2 refocused on safety teams." },
      { name: "V1 outreach scripts (stale)", file: "OUTREACH_SCRIPTS.md", desc: "V1 outreach scripts targeting perception teams. V2 outreach targets safety teams + regulatory officers." },
    ],
  },
  {
    section: "Simulation source",
    description: "Physical-layer simulation that backed V1 quantitative claims. Most of the V1 sim modeled vehicle-mounted operations; V2 thesis-relevant components survive but full V2 site-deployment sim is post-pre-seed work.",
    items: [
      { name: "Simulation repo", file: "skydock/", desc: "Discrete-time full-system simulation. Trigger arrivals → mission state machine → data pipeline → unit economics. 16 passing regression tests. V1 mobile-dock model; useful for methodology reference." },
      { name: "Live demo on landing page (V1)", file: "../", desc: "V2 customer site replaces the V1 simulation animation. V1 demo gif remains in repo public/ but is not surfaced on the V2 customer site." },
    ],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Internal investor materials — confidential" />
    <title>Skydock — Internal & Investor Materials</title>
    <style is:global>
      :root {
        --bg: #0a0e1a;
        --bg-elev: #111827;
        --border: #1f2937;
        --text: #e5e7eb;
        --text-dim: #9ca3af;
        --text-strong: #f9fafb;
        --accent: #60a5fa;
        --accent-soft: rgba(96, 165, 250, 0.08);
        --warn: #e5b85a;
        --warn-soft: rgba(229, 184, 90, 0.12);
        --danger: #d97757;
        --mono: 'SF Mono', 'Monaco', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
        --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        line-height: 1.65;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.15s ease;
      }
      a:hover { border-bottom-color: var(--accent); }
      .container {
        max-width: 820px;
        margin: 0 auto;
        padding: 0 24px;
      }
      header.site-header {
        padding: 24px 0;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
      }
      .site-header .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .brand {
        font-family: var(--mono);
        font-size: 18px;
        letter-spacing: 0.02em;
        color: var(--text-strong);
      }
      .brand::before {
        content: '◆ ';
        color: var(--accent);
      }
      .internal-badge {
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--warn);
        background: var(--warn-soft);
        padding: 4px 10px;
        border-radius: 3px;
        border: 1px solid rgba(229, 184, 90, 0.3);
      }
      section.hero {
        padding: 64px 0 48px;
      }
      h1 {
        font-size: clamp(32px, 5vw, 44px);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin-bottom: 20px;
        color: var(--text-strong);
      }
      .hero p.subline {
        font-size: 17px;
        color: var(--text-dim);
        max-width: 680px;
      }
      .confidential-note {
        background: var(--warn-soft);
        border: 1px solid rgba(229, 184, 90, 0.3);
        border-left: 3px solid var(--warn);
        border-radius: 4px;
        padding: 16px 20px;
        margin: 28px 0;
        font-size: 14px;
        color: var(--text);
        line-height: 1.5;
      }
      .confidential-note strong {
        color: var(--warn);
        font-family: var(--mono);
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.08em;
        display: block;
        margin-bottom: 6px;
      }
      section {
        padding: 48px 0;
        border-top: 1px solid var(--border);
      }
      h2 {
        font-size: 13px;
        font-family: var(--mono);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
        margin-bottom: 8px;
        font-weight: 500;
      }
      .section-desc {
        font-size: 16px;
        color: var(--text-dim);
        margin-bottom: 24px;
      }
      .doc-list {
        list-style: none;
      }
      .doc-item {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 18px 22px;
        margin-bottom: 12px;
      }
      .doc-name {
        font-family: var(--mono);
        font-size: 14px;
        color: var(--accent);
        font-weight: 500;
        margin-bottom: 6px;
      }
      .doc-name a { color: var(--accent); }
      .doc-desc {
        color: var(--text);
        font-size: 14.5px;
        line-height: 1.55;
      }
      .section-note {
        margin-top: 18px;
        font-size: 13px;
        color: var(--text-dim);
        font-style: italic;
      }
      .quick-facts {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 22px 24px;
        margin: 24px 0;
      }
      .quick-facts h4 {
        font-family: var(--mono);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
        margin-bottom: 14px;
      }
      .quick-facts ul {
        list-style: none;
      }
      .quick-facts ul li {
        padding: 6px 0;
        font-size: 14.5px;
        color: var(--text);
      }
      .quick-facts ul li strong {
        color: var(--text-strong);
        font-family: var(--mono);
        font-size: 13.5px;
        margin-right: 8px;
      }
      footer {
        padding: 40px 0;
        border-top: 1px solid var(--border);
        text-align: center;
        color: var(--text-dim);
        font-family: var(--mono);
        font-size: 12px;
      }
      footer a { color: var(--text-dim); }
      footer a:hover { color: var(--accent); }

      /* Password gate */
      #content { display: none; }
      #gate {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .gate-card {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 40px 36px;
        max-width: 460px;
        width: 100%;
      }
      .gate-card h2 {
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 12px;
        color: var(--text-strong);
        font-family: var(--sans);
        text-transform: none;
        letter-spacing: -0.01em;
      }
      .gate-card p {
        font-size: 14.5px;
        color: var(--text-dim);
        margin-bottom: 24px;
        line-height: 1.55;
      }
      .gate-card form {
        display: flex;
        gap: 10px;
        margin-bottom: 18px;
      }
      .gate-card input[type=password] {
        flex: 1;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 12px 14px;
        color: var(--text-strong);
        font-family: var(--mono);
        font-size: 14px;
        outline: none;
      }
      .gate-card input[type=password]:focus {
        border-color: var(--accent);
      }
      .gate-card button {
        background: var(--accent);
        color: #0a0e1a;
        border: none;
        border-radius: 6px;
        padding: 12px 22px;
        font-family: var(--mono);
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
      }
      .gate-card button:hover { background: #7ab1f5; }
      .gate-error {
        color: var(--danger);
        font-family: var(--mono);
        font-size: 12px;
        min-height: 16px;
      }
      .gate-footnote {
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        font-size: 12px;
        color: var(--text-dim);
        line-height: 1.5;
      }
      .gate-footnote a { color: var(--accent); }
    </style>
    <script is:inline define:vars={{ PASSWORD_HASH }}>
      (async function () {
        // Check existing session auth
        if (sessionStorage.getItem("skydock_investor_auth") === "1") {
          document.addEventListener("DOMContentLoaded", () => {
            document.getElementById("gate").style.display = "none";
            document.getElementById("content").style.display = "block";
          });
          return;
        }
        // Wire up the password form
        document.addEventListener("DOMContentLoaded", () => {
          const form = document.getElementById("gate-form");
          const input = document.getElementById("gate-pw");
          const errEl = document.getElementById("gate-err");
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            errEl.textContent = "";
            const pw = input.value;
            const enc = new TextEncoder();
            const data = enc.encode(pw);
            const hashBuf = await crypto.subtle.digest("SHA-256", data);
            const hashHex = Array.from(new Uint8Array(hashBuf))
              .map(b => b.toString(16).padStart(2, "0"))
              .join("");
            if (hashHex === PASSWORD_HASH) {
              sessionStorage.setItem("skydock_investor_auth", "1");
              document.getElementById("gate").style.display = "none";
              document.getElementById("content").style.display = "block";
            } else {
              errEl.textContent = "Incorrect password. Contact krethikram@gmail.com for access.";
              input.value = "";
              input.focus();
            }
          });
          input.focus();
        });
      })();
    </script>
  </head>
  <body>
    <div id="gate">
      <div class="gate-card">
        <h2>Access required</h2>
        <p>
          This page contains confidential strategic materials, financial
          projections, and competitive analysis. Enter the access password
          to continue.
        </p>
        <form id="gate-form">
          <input id="gate-pw" type="password" placeholder="access password" autocomplete="off" />
          <button type="submit">Enter</button>
        </form>
        <div id="gate-err" class="gate-error"></div>
        <div class="gate-footnote">
          Don't have access? Email <a href="mailto:krethikram@gmail.com?subject=Skydock — investor materials access request">krethikram@gmail.com</a> with the context of your interest (investor / prospective hire / customer).
        </div>
      </div>
    </div>

    <div id="content">
    <header class="site-header">
      <div class="container row">
        <span class="brand">skydock</span>
        <span class="internal-badge">internal · confidential</span>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container">
          <h1>Internal &amp; Investor Materials</h1>
          <p class="subline">
            Strategic narrative, financial model, market research, and
            execution plan. Linked materials live on the public GitHub
            repository but are not indexed from the customer site nav.
          </p>

          <div class="confidential-note">
            <strong>Confidential</strong>
            These materials are intended for investors, prospective hires,
            and the founder's working group. They contain candid risk
            assessments, internal financial assumptions, and competitive
            analysis not suitable for public sharing. Please do not
            redistribute without permission.
          </div>

          <div class="quick-facts">
            <h4>Quick reference (V2)</h4>
            <ul>
              <li><strong>Stage</strong> Pre-seed (V2 closed-loop pilot acquisition + raise)</li>
              <li><strong>Architecture</strong> V2 fixed-point capture + library subscription (pivoted from V1 mobile-dock May 2026)</li>
              <li><strong>Raise size</strong> $2.2M on SAFE @ $12M post-money cap (~18% dilution)</li>
              <li><strong>CFP target</strong> Month 18-20 from raise close, $900K-$1.2M ARR run-rate</li>
              <li><strong>Cash at M18</strong> ~$600K (4 months buffer at mature burn)</li>
              <li><strong>Founder ownership post-seed</strong> ~50% (solo founder)</li>
              <li><strong>Mature LTV per customer</strong> $297K gross profit; LTV/CAC 3.7×</li>
              <li><strong>Unit economics</strong> $2/scenario delivered (vs V1 $87)</li>
              <li><strong>Customer site (V2)</strong> <a href="../">skydock landing page</a></li>
              <li><strong>Contact</strong> <a href="mailto:krethikram@gmail.com">krethikram@gmail.com</a></li>
            </ul>
          </div>
        </div>
      </section>

      {docs.map((section) => (
        <section>
          <div class="container">
            <h2>{section.section}</h2>
            <p class="section-desc">{section.description}</p>
            <ul class="doc-list">
              {section.items.map((item) => (
                <li class="doc-item">
                  <div class="doc-name">
                    <a href={`${repoBase}/${item.file}`} target="_blank" rel="noopener">{item.name} →</a>
                  </div>
                  <div class="doc-desc">{item.desc}</div>
                </li>
              ))}
            </ul>
            {section.note && <p class="section-note">{section.note}</p>}
          </div>
        </section>
      ))}

      <section>
        <div class="container">
          <h2>How to use these materials</h2>
          <ul class="doc-list">
            <li class="doc-item">
              <div class="doc-name">For investors</div>
              <div class="doc-desc">
                Start with the <strong>V2 thesis</strong> for the strategic
                framing of the May 2026 pivot. Then the
                <strong>V2 PR-FAQ (PITCH.md)</strong> for the full
                narrative — closed-loop validation problem, library
                subscription product, fixed-point unit economics. Skim
                <strong>V2 financial model</strong> for the dollar math
                and <strong>Equity Projection</strong> for the cap table.
                <strong>V2 execution plan</strong> for the 18-month
                operational roadmap.
              </div>
            </li>
            <li class="doc-item">
              <div class="doc-name">For prospective hires</div>
              <div class="doc-desc">
                Start with the <strong>V2 thesis</strong>, then the
                <strong>V2 PR-FAQ</strong>. <strong>V2 execution plan</strong>
                shows the 18-month operational roadmap and the engineering
                + curation hiring sequence. <strong>Competitive graveyard</strong>
                and <strong>Regulatory + permits</strong> are the most
                candid view of risks. V1 docs in the historical section give
                context on why we pivoted from mobile-dock.
              </div>
            </li>
            <li class="doc-item">
              <div class="doc-name">For customer-discovery prospects</div>
              <div class="doc-desc">
                The customer-facing site (linked above) is the primary
                resource. <strong>Model performance evidence</strong> and
                <strong>Data value + long-tail research</strong> docs here
                provide the deeper sourced research backing the site's
                headline numbers — share on request.
              </div>
            </li>
          </ul>
        </div>
      </section>
    </main>

    <footer>
      <div class="container">
        skydock · 2026 · internal data room · V2 architecture · last updated June 2026 · <a href="../">customer site</a>
      </div>
    </footer>
    </div>
  </body>
</html>
