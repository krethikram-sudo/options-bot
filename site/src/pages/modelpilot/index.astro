---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="ModelPilot — private beta" />
    <title>ModelPilot — cut your Claude bill 30–50%, with proof</title>
    <style is:global>
      :root { --ink:#1f2430; --mut:#6b7080; --green:#2e9e5b; --blue:#2f6fb6; --line:#e3e3e8; }
      * { box-sizing: border-box; }
      body { font: 16px/1.6 -apple-system, "Segoe UI", sans-serif; color: var(--ink); margin: 0; }
      .wrap { max-width: 880px; margin: 0 auto; padding: 0 1.2rem; }
      header.hero { padding: 4rem 0 3rem; background: linear-gradient(#fbfefc, #fff); }
      .tag { font-size: .8rem; letter-spacing: .08em; text-transform: uppercase; color: var(--green); font-weight: 700; }
      h1 { font-size: 2.2rem; line-height: 1.2; margin: .4rem 0 1rem; }
      .sub { font-size: 1.12rem; color: var(--mut); max-width: 640px; }
      .cta { margin-top: 1.6rem; display: flex; gap: 12px; flex-wrap: wrap; }
      .btn { display: inline-block; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; }
      .btn.primary { background: var(--green); color: #fff; }
      .btn.ghost { border: 1px solid var(--line); color: var(--ink); }
      .term { background: #14181f; color: #d7e0ea; border-radius: 10px; padding: 16px 18px;
              font: 13px/1.7 ui-monospace, Menlo, monospace; margin: 2.2rem 0 0; overflow-x: auto; }
      .term .c { color: #6b7080; } .term .g { color: #79d29a; } .term .y { color: #e7c46b; }
      section { padding: 2.4rem 0; border-top: 1px solid #f0f0f3; }
      h2 { font-size: 1.3rem; margin: 0 0 1rem; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
      .card { border: 1px solid var(--line); border-radius: 10px; padding: 16px 18px; }
      .card h3 { margin: 0 0 6px; font-size: 1rem; }
      .card p { margin: 0; color: var(--mut); font-size: .92rem; }
      table { border-collapse: collapse; width: 100%; font-size: .92rem; }
      td, th { border-bottom: 1px solid #eee; padding: 8px 10px; text-align: left; }
      th { color: var(--mut); }
      code { background: #f6f7f9; border-radius: 4px; padding: 1px 6px; font-size: .88em; }
      pre.block { background: #f6f7f9; border-radius: 8px; padding: 12px 14px; overflow-x: auto; font-size: .85rem; }
      footer { padding: 2.4rem 0 3.4rem; color: var(--mut); font-size: .85rem; border-top: 1px solid #f0f0f3; }
      .note { background: #fbfefc; border: 1px solid #d8efe0; border-radius: 10px; padding: 14px 18px; font-size: .92rem; }
      ol.steps { padding-left: 1.3rem; margin: 0; }
      ol.steps > li { margin: 0 0 1.1rem; }
      ol.steps pre.block { margin: 8px 0 0; }

      /* ---- self-playing animated product demo ---- */
      .demo-wrap { max-width: 760px; margin: 1.4rem auto 0; }
      .demo-win { border: 1px solid var(--line); border-radius: 12px; overflow: hidden;
                  box-shadow: 0 10px 40px rgba(31,36,48,.10); background: #fff; }
      .demo-top { display: flex; align-items: center; gap: 6px; padding: 9px 12px;
                  background: #f3f4f6; border-bottom: 1px solid var(--line); }
      .demo-top i { width: 11px; height: 11px; border-radius: 50%; background: #d7d9de; display: inline-block; }
      .demo-top i.r { background: #ef6a5e; } .demo-top i.y { background: #f4be4f; } .demo-top i.g { background: #61c25a; }
      .demo-top span { margin-left: 8px; color: var(--mut); font-size: .8rem; }
      .demo-cap { text-align: center; font-size: .8rem; color: var(--mut); padding: 8px 0 0; }
      .demo-screen { position: relative; min-height: 290px; padding: 18px 20px; }
      .scene { display: none; }
      .scene.on { display: block; animation: dfade .45s ease; }
      @keyframes dfade { from { opacity: 0; transform: translateY(8px);} to { opacity: 1; transform: none; } }
      .term2 { font: 13px/1.8 ui-monospace, Menlo, monospace; color: #1f2430; }
      .term2 .cmd { color: #1f2430; } .term2 .dim { color: #9aa0ab; }
      .scene.on .row { opacity: 0; animation: rowin .4s ease forwards; }
      .scene.on .row:nth-child(1){animation-delay:.10s}.scene.on .row:nth-child(2){animation-delay:.45s}
      .scene.on .row:nth-child(3){animation-delay:.80s}.scene.on .row:nth-child(4){animation-delay:1.15s}
      .scene.on .row:nth-child(5){animation-delay:1.5s}.scene.on .row:nth-child(6){animation-delay:1.85s}
      .scene.on .row:nth-child(7){animation-delay:2.2s}
      @keyframes rowin { from { opacity: 0; transform: translateX(-6px);} to { opacity: 1; transform: none; } }
      .pill { font-size: .72rem; padding: 1px 7px; border-radius: 10px; }
      .pill.save { background: #eaf7ef; color: #1e7a44; } .pill.keep { background: #f6f7f9; color: #6b7080; }
      .kpi { font-size: 2.2rem; font-weight: 800; color: var(--green); line-height: 1.1; }
      .kpi small { font-size: .95rem; font-weight: 600; color: var(--mut); }
      .sxs2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; }
      .sxs2 .col { border: 1px solid var(--line); border-radius: 8px; padding: 9px 11px; font-size: .82rem; }
      .sxs2 .col.win { border-color: #cfead9; background: #f6fbf8; }
      .sxs2 h5 { margin: 0 0 5px; font-size: .76rem; color: var(--mut); font-weight: 600; }
      .bars { margin-top: 10px; } .barrow { display: flex; align-items: center; gap: 10px; margin: 9px 0; }
      .barrow .lab { width: 70px; color: var(--mut); font-size: .8rem; }
      .barrow .track { flex: 1; background: #f1f2f4; border-radius: 6px; height: 18px; overflow: hidden; }
      .barrow .fill { height: 100%; background: linear-gradient(90deg,#9ad9b3,#2e9e5b); width: 0; border-radius: 6px; }
      .scene.on .fill { animation: grow 1.1s cubic-bezier(.2,.7,.3,1) forwards; }
      .barrow .pct { width: 42px; text-align: right; font-weight: 700; color: var(--green); font-size: .85rem; }
      @keyframes grow { from { width: 0; } }
      /* live-demo product-screen look */
      .reqlog { font: 12.5px/2 ui-monospace, Menlo, monospace; }
      .reqlog .m { color: #9aa0ab; } .reqlog b { color: #1f2430; }
      .reqlog .ok { color: #1e7a44; } .reqlog .keep2 { color: #6b7080; }
      .dashhead { display: flex; gap: 8px; align-items: baseline; margin-bottom: 12px; flex-wrap: wrap; }
      .dashhead b { font-size: 1rem; } .dashhead .mode { color: var(--mut); font-size: .78rem; }
      .convbox { border: 1px solid #f0d9a8; background: #fffdf5; border-radius: 10px; padding: 12px 14px; }
      .convbox .h { font-size: .72rem; letter-spacing: .05em; font-weight: 700; color: #b8860b; }
      .convbox .big { font-size: 1.6rem; font-weight: 800; color: var(--green); line-height: 1.2; margin-top: 4px; }
      .convbox .big small { font-size: .85rem; font-weight: 600; color: var(--mut); }
      .stripline { display: flex; gap: 20px; margin-top: 12px; font-size: .82rem; color: var(--mut); flex-wrap: wrap; }
      .stripline b { color: var(--ink); }

      /* Password gate */
      #content { display: none; }
      #gate { position: fixed; inset: 0; background: #fbfefc; display: flex;
              align-items: center; justify-content: center; z-index: 1000; }
      .gate-card { background: #fff; border: 1px solid var(--line); border-radius: 12px;
                   padding: 28px 30px; max-width: 420px; width: 92%;
                   box-shadow: 0 4px 24px rgba(31,36,48,.08); }
      .gate-card .tag { margin-bottom: 4px; display: block; }
      .gate-card h2 { margin: 0 0 8px; font-size: 1.2rem; }
      .gate-card p { color: var(--mut); font-size: .92rem; margin: 0 0 14px; }
      .gate-card form { display: flex; gap: 8px; }
      .gate-card input[type=password] { flex: 1; font: inherit; padding: 9px 12px;
        border: 1px solid var(--line); border-radius: 8px; }
      .gate-card input[type=password]:focus { outline: none; border-color: var(--green); }
      .gate-card button { font: inherit; font-weight: 600; padding: 9px 18px; border: 0;
        border-radius: 8px; background: var(--green); color: #fff; cursor: pointer; }
      .gate-error { color: #b3372f; font-size: .85rem; margin-top: 10px; min-height: 1.2em; }
      .gate-footnote { color: var(--mut); font-size: .8rem; margin-top: 14px;
        border-top: 1px solid #f0f0f3; padding-top: 12px; }
      .gate-footnote a { color: var(--blue); }
    </style>
    <script is:inline define:vars={{ PASSWORD_HASH }}>
      (async function () {
        if (sessionStorage.getItem("modelpilot_beta_auth") === "1") {
          document.addEventListener("DOMContentLoaded", () => {
            document.getElementById("gate").style.display = "none";
            document.getElementById("content").style.display = "block";
          });
          return;
        }
        document.addEventListener("DOMContentLoaded", () => {
          const form = document.getElementById("gate-form");
          const input = document.getElementById("gate-pw");
          const errEl = document.getElementById("gate-err");
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            errEl.textContent = "";
            const enc = new TextEncoder();
            const hashBuf = await crypto.subtle.digest("SHA-256", enc.encode(input.value));
            const hashHex = Array.from(new Uint8Array(hashBuf))
              .map((b) => b.toString(16).padStart(2, "0")).join("");
            if (hashHex === PASSWORD_HASH) {
              sessionStorage.setItem("modelpilot_beta_auth", "1");
              document.getElementById("gate").style.display = "none";
              document.getElementById("content").style.display = "block";
            } else {
              errEl.textContent = "Incorrect password.";
              input.value = "";
              input.focus();
            }
          });
          input.focus();
        });
      })();
    </script>
  </head>
  <body>
    <div id="gate">
      <div class="gate-card">
        <span class="tag">ModelPilot · private beta</span>
        <h2>Access required</h2>
        <p>This page describes a product in private beta. Enter the access
        password to continue.</p>
        <form id="gate-form">
          <input id="gate-pw" type="password" placeholder="access password" autocomplete="off" />
          <button type="submit">Enter</button>
        </form>
        <div id="gate-err" class="gate-error"></div>
        <div class="gate-footnote">
          Don't have access? Email <a href={`mailto:${CONTACT}?subject=ModelPilot beta access request`}>{CONTACT}</a>
          with a sentence about your Claude usage — we'll send the password and a repo invite.
        </div>
      </div>
    </div>

    <div id="content">
      <header class="hero"><div class="wrap">
        <div class="tag">ModelPilot · private beta</div>
        <h1>Cut your Claude bill 30–50%.<br />See the proof, live.</h1>
