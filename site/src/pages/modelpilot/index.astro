---
// SHA-256 hash of the access password. Default: "modelpilot-beta-2026"
// To change: compute new hash via:  echo -n "your-new-password" | shasum -a 256
const PASSWORD_HASH = "ebe9105e7f6d8847c5943b9c84a7ef5004c8ca3aefb5add8515641b55f6363e6";
const CONTACT = "krethikram@gmail.com";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="ModelPilot — private beta" />
    <title>ModelPilot — cut your Claude bill 30–50%, with proof</title>
    <style is:global>
      :root { --ink:#1f2430; --mut:#6b7080; --green:#2e9e5b; --blue:#2f6fb6; --line:#e3e3e8; }
      * { box-sizing: border-box; }
      body { font: 16px/1.6 -apple-system, "Segoe UI", sans-serif; color: var(--ink); margin: 0; }
      .wrap { max-width: 880px; margin: 0 auto; padding: 0 1.2rem; }
      header.hero { padding: 4rem 0 3rem; background: linear-gradient(#fbfefc, #fff); }
      .tag { font-size: .8rem; letter-spacing: .08em; text-transform: uppercase; color: var(--green); font-weight: 700; }
      h1 { font-size: 2.2rem; line-height: 1.2; margin: .4rem 0 1rem; }
      .sub { font-size: 1.12rem; color: var(--mut); max-width: 640px; }
      .cta { margin-top: 1.6rem; display: flex; gap: 12px; flex-wrap: wrap; }
      .btn { display: inline-block; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; }
      .btn.primary { background: var(--green); color: #fff; }
      .btn.ghost { border: 1px solid var(--line); color: var(--ink); }
      .term { background: #14181f; color: #d7e0ea; border-radius: 10px; padding: 16px 18px;
              font: 13px/1.7 ui-monospace, Menlo, monospace; margin: 2.2rem 0 0; overflow-x: auto; }
      .term .c { color: #6b7080; } .term .g { color: #79d29a; } .term .y { color: #e7c46b; }
      section { padding: 2.4rem 0; border-top: 1px solid #f0f0f3; }
      h2 { font-size: 1.3rem; margin: 0 0 1rem; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
      .card { border: 1px solid var(--line); border-radius: 10px; padding: 16px 18px; }
      .card h3 { margin: 0 0 6px; font-size: 1rem; }
      .card p { margin: 0; color: var(--mut); font-size: .92rem; }
      table { border-collapse: collapse; width: 100%; font-size: .92rem; }
      td, th { border-bottom: 1px solid #eee; padding: 8px 10px; text-align: left; }
      th { color: var(--mut); }
      code { background: #f6f7f9; border-radius: 4px; padding: 1px 6px; font-size: .88em; }
      pre.block { background: #f6f7f9; border-radius: 8px; padding: 12px 14px; overflow-x: auto; font-size: .85rem; }
      footer { padding: 2.4rem 0 3.4rem; color: var(--mut); font-size: .85rem; border-top: 1px solid #f0f0f3; }
      .note { background: #fbfefc; border: 1px solid #d8efe0; border-radius: 10px; padding: 14px 18px; font-size: .92rem; }
      ol.steps { padding-left: 1.3rem; margin: 0; }
      ol.steps > li { margin: 0 0 1.1rem; }
      ol.steps pre.block { margin: 8px 0 0; }

      /* Password gate */
      #content { display: none; }
      #gate { position: fixed; inset: 0; background: #fbfefc; display: flex;
              align-items: center; justify-content: center; z-index: 1000; }
      .gate-card { background: #fff; border: 1px solid var(--line); border-radius: 12px;
                   padding: 28px 30px; max-width: 420px; width: 92%;
                   box-shadow: 0 4px 24px rgba(31,36,48,.08); }
      .gate-card .tag { margin-bottom: 4px; display: block; }
      .gate-card h2 { margin: 0 0 8px; font-size: 1.2rem; }
      .gate-card p { color: var(--mut); font-size: .92rem; margin: 0 0 14px; }
      .gate-card form { display: flex; gap: 8px; }
      .gate-card input[type=password] { flex: 1; font: inherit; padding: 9px 12px;
        border: 1px solid var(--line); border-radius: 8px; }
      .gate-card input[type=password]:focus { outline: none; border-color: var(--green); }
      .gate-card button { font: inherit; font-weight: 600; padding: 9px 18px; border: 0;
        border-radius: 8px; background: var(--green); color: #fff; cursor: pointer; }
      .gate-error { color: #b3372f; font-size: .85rem; margin-top: 10px; min-height: 1.2em; }
      .gate-footnote { color: var(--mut); font-size: .8rem; margin-top: 14px;
        border-top: 1px solid #f0f0f3; padding-top: 12px; }
      .gate-footnote a { color: var(--blue); }
    </style>
    <script is:inline define:vars={{ PASSWORD_HASH }}>
      (async function () {
        if (sessionStorage.getItem("modelpilot_beta_auth") === "1") {
          document.addEventListener("DOMContentLoaded", () => {
            document.getElementById("gate").style.display = "none";
            document.getElementById("content").style.display = "block";
          });
          return;
        }
        document.addEventListener("DOMContentLoaded", () => {
          const form = document.getElementById("gate-form");
          const input = document.getElementById("gate-pw");
          const errEl = document.getElementById("gate-err");
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            errEl.textContent = "";
            const enc = new TextEncoder();
            const hashBuf = await crypto.subtle.digest("SHA-256", enc.encode(input.value));
            const hashHex = Array.from(new Uint8Array(hashBuf))
              .map((b) => b.toString(16).padStart(2, "0")).join("");
            if (hashHex === PASSWORD_HASH) {
              sessionStorage.setItem("modelpilot_beta_auth", "1");
              document.getElementById("gate").style.display = "none";
              document.getElementById("content").style.display = "block";
            } else {
              errEl.textContent = "Incorrect password.";
              input.value = "";
              input.focus();
            }
          });
          input.focus();
        });
      })();
    </script>
  </head>
  <body>
    <div id="gate">
      <div class="gate-card">
        <span class="tag">ModelPilot · private beta</span>
        <h2>Access required</h2>
        <p>This page describes a product in private beta. Enter the access
        password to continue.</p>
        <form id="gate-form">
          <input id="gate-pw" type="password" placeholder="access password" autocomplete="off" />
          <button type="submit">Enter</button>
        </form>
        <div id="gate-err" class="gate-error"></div>
        <div class="gate-footnote">
          Don't have access? Email <a href={`mailto:${CONTACT}?subject=ModelPilot beta access request`}>{CONTACT}</a>
          with a sentence about your Claude usage — we'll send the password and a repo invite.
        </div>
      </div>
    </div>

    <div id="content">
      <header class="hero"><div class="wrap">
        <div class="tag">ModelPilot · private beta</div>
        <h1>Cut your Claude bill 30–50%.<br />See the proof, live.</h1>
        <p class="sub">A drop-in gateway that routes every request to the cheapest Claude
        model that's provably good enough — informed by the whole conversation, never
        downgrading hard work — and shows you exactly what you saved, per prompt and
        per session, recalculated from the actual tokens each request consumed.</p>
        <div class="cta">
          <a class="btn primary" href={`mailto:${CONTACT}?subject=ModelPilot beta — repo invite`}>Request beta access →</a>
          <a class="btn ghost" href="#quickstart">2-minute quickstart</a>
        </div>
        <pre class="term"><span class="c"># no API key, no spend — see it route in two minutes</span>
$ pip install "modelpilot @ git+https://github.com/krethikram-sudo/modelpilot.git"
$ modelpilot demo --offline

  1 classification    <span class="g">SWITCH → claude-haiku-4-5</span>   conf 0.85
  2 debugging         <span class="y">stay   → claude-opus-4-8</span>    quality protected
  3 extraction        <span class="g">SWITCH → claude-haiku-4-5</span>   conf 0.85
  ...
REALIZED savings: <span class="g">$0.07</span>   POTENTIAL: $0.12  <span class="g">(48% of baseline)</span></pre>
      </div></header>

      <section><div class="wrap">
        <h2>Two modes. Start in guidance, switch when convinced.</h2>
        <div class="grid">
          <div class="card"><h3>Guidance <span style="color:var(--green)">· start here</span></h3>
            <p>Nothing about your traffic changes. ModelPilot scores every request and
            shows you, on the dashboard, exactly what autopilot <em>would</em> save —
            so you decide with evidence, at zero risk.</p></div>
          <div class="card"><h3>Autopilot <span style="color:var(--mut)">· when ready</span></h3>
            <p>Confidence-gated routing with a built-in randomized holdout, so the
            savings are <em>measured</em>, not estimated — and an escalation valve whose
            costs count against us. Flip one flag when the dashboard convinces you.</p></div>
        </div>
        <p class="note" style="margin-top:1rem">The recommended rollout:
        <b>run in guidance → read the dashboard → switch to autopilot.</b>
        The dashboard is built to earn that switch — it shows the would-have-saved
        number and the side-by-side proof that the cheaper model's output holds up.</p>
      </div></section>

      <section><div class="wrap">
        <h2>Why the routing is trustworthy</h2>
        <table>
          <tr><th>Hard problem</th><th>How ModelPilot handles it</th></tr>
          <tr><td>"Summarize" can be trivial or expert-level</td>
              <td>Calibrated on a golden dataset with a ≤2% false-downgrade target;
                  when unsure, it doesn't touch your request</td></tr>
          <tr><td>"why?" after a hard exchange looks trivial</td>
              <td>Session-context routing: follow-ups inherit the conversation's
                  difficulty; mechanical tasks over existing content stay cheap</td></tr>
          <tr><td>Prompt caches are model-scoped — naive switching loses money</td>
              <td>Cache-aware economics price the rewrite before any mid-conversation
                  switch and veto switches that don't pay</td></tr>
          <tr><td>Vendors grade their own homework</td>
              <td>Randomized holdout + escalation costs deducted + side-by-side output
                  comparisons on your own traffic: <code>modelpilot compare --from-captures --judge</code></td></tr>
        </table>
      </div></section>

      <section><div class="wrap">
        <h2>The proof — embedded in your dashboard, on your own traffic</h2>
        <p>This is what turns a guidance trial into an autopilot customer. Your own
        captured prompts, run through both arms — ModelPilot's routing vs everything
        on the biggest model — rendered <b>side by side right on the dashboard</b>:
        each prompt, both outputs, per-chat and cumulative savings, and an independent
        non-inferiority verdict.</p>
        <pre class="block">$ modelpilot compare --from-captures --judge --save-to-db
routed 14/20 prompts · saved 61% ($1.87) · non-inferior 100%
# → now rendered in the dashboard's side-by-side proof panel</pre>
        <p class="note">Savings you can audit: actual token counts at list prices, the
        same prompts in both arms, every output on the page for your own eyes.
        <b>And it improves with use</b> — <code>modelpilot tune</code> learns from your
        traffic, loosening routing where it proves safe for your workload and backing
        off anywhere it doesn't, so savings climb the longer you run it.</p>
      </div></section>

      <section id="quickstart"><div class="wrap">
        <h2>How to use it — start to finish</h2>
        <p class="note" style="border-color:#f0d9a8;background:#fffdf5">
          <b>What you need:</b> a <b>billable Anthropic API key</b>
          (<a href="https://console.anthropic.com">console.anthropic.com</a>) and an
          app or service that calls the Claude API. <b>Use your real key from the
          start</b> — you begin in <b>guidance mode</b>, which uses your key but
          <em>changes nothing</em> about your traffic (zero risk), then switch to
          autopilot once the dashboard convinces you. A Claude.ai / Claude Code
          <em>subscription</em> can't be optimized (it's flat-rate, not per-token).
          Python 3.10+.</p>
        <ol class="steps">
          <li><b>Get access.</b> Reply to your invite with your GitHub username; we
            add you to the private repo and you'll get an email from GitHub.</li>

          <li><b>Install</b> (Python 3.10+):
            <pre class="block">pip install "modelpilot @ git+https://github.com/krethikram-sudo/modelpilot.git"</pre></li>

          <li><b>Set your Anthropic API key</b>, then <b>start the gateway in guidance
            mode</b> — it measures and recommends but changes nothing. Turn on prompt
            capture so you can generate the proof later:
            <pre class="block">export ANTHROPIC_API_KEY=sk-ant-...
MODELPILOT_CAPTURE_PCT=1.0 modelpilot gateway --mode guidance --port 8400</pre>
            <span class="muted">Tip: the key lives in your app (step 5); the gateway just
            forwards it. Setting it here is only needed for the chat playground / demo.</span></li>

          <li><b>Point one app at the gateway</b> — a one-line base-URL change. Your
            API key stays in your app, passes through, and is never stored:
            <pre class="block">Python:      anthropic.Anthropic(base_url="http://localhost:8400")
TypeScript:  new Anthropic(&#123; baseURL: "http://localhost:8400" &#125;)
Claude Code / any SDK:  export ANTHROPIC_BASE_URL=http://localhost:8400</pre>
            Then use your app exactly as you do today — every request flows through and is scored.</li>

          <li><b>Open the dashboard</b> and read the headline: what autopilot
            <em>would</em> save, per chat and cumulative.
            <pre class="block">open http://localhost:8400/modelpilot/dashboard</pre></li>

          <li><b>Generate the side-by-side proof</b> on your own prompts — recommended
            model vs standard model, both outputs, costs, and non-inferiority verdicts,
            rendered right on the dashboard:
            <pre class="block">modelpilot compare --from-captures --judge --save-to-db</pre></li>

          <li><b>Switch to autopilot</b> when the evidence convinces you. It routes
            automatically, keeps a randomized holdout running to prove quality parity,
            and continuously re-tunes to your traffic:
            <pre class="block">modelpilot gateway --mode autopilot --port 8400</pre></li>
        </ol>
        <p class="note"><b>Kill switch any time:</b> revert the base URL, or run
        <code>--mode guidance</code> to stop all rerouting. <b>Privacy:</b> no prompt
        text is stored by default — the ledger holds token counts and routing metadata
        only (capture in step 4 is opt-in and stays in your deployment). <b>It improves
        with use:</b> in autopilot ModelPilot keeps re-tuning per-category routing to
        your workload — capturing more where it's proven safe, backing off anywhere
        quality slips.</p>
      </div></section>

      <footer><div class="wrap">
        ModelPilot · private beta · <a href={`mailto:${CONTACT}`}>{CONTACT}</a><br />
        Model prices referenced: Claude Fable 5 $10/$50 · Opus 4.8 $5/$25 ·
        Sonnet 4.6 $3/$15 · Haiku 4.5 $1/$5 per MTok (June 2026 list).
      </div></footer>
    </div>
  </body>
</html>
