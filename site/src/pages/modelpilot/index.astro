    <script is:inline>
      (function () {
        function start() {
          var demo = document.getElementById("mp-demo");
          if (!demo) return;
          var scenes = demo.querySelectorAll(".scene");
          if (!scenes.length) return;
          var i = 0;
          // per-scene dwell (ms): request log, dashboard, proof (longest to read), autopilot
          var dwell = [5600, 5200, 6000, 5400];
          function tick() {
            scenes.forEach(function (s, k) { s.classList.toggle("on", k === i); });
            var wait = dwell[i] || 4800;
            i = (i + 1) % scenes.length;
            setTimeout(tick, wait);
          }
          tick();
        }
        if (document.readyState !== "loading") start();
        else document.addEventListener("DOMContentLoaded", start);
      })();
    </script>
