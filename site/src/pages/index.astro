---
const tagline = "Aerial ground-truth capture for autonomous-vehicle perception.";
const subline = "Skydock builds the first vehicle-deployed aerial drone platform for AV training data. The wedge: a structurally missing category in AV scenario libraries — aerial bird's-eye-view — that AV teams have been trying to source internally for years.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={tagline} />
    <meta property="og:title" content="Skydock — Aerial ground-truth for AV perception" />
    <meta property="og:description" content={tagline} />
    <meta property="og:type" content="website" />
    <title>Skydock — Aerial ground-truth for AV perception</title>
    <style is:global>
      :root {
        --bg: #0a0e1a;
        --bg-elev: #111827;
        --border: #1f2937;
        --text: #e5e7eb;
        --text-dim: #9ca3af;
        --text-strong: #f9fafb;
        --accent: #60a5fa;
        --accent-dim: #1e3a8a;
        --accent-soft: rgba(96, 165, 250, 0.08);
        --good: #9ee37d;
        --warn: #e5b85a;
        --mono: 'SF Mono', 'Monaco', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
        --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        line-height: 1.65;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.15s ease;
      }
      a:hover { border-bottom-color: var(--accent); }
      .container {
        max-width: 820px;
        margin: 0 auto;
        padding: 0 24px;
      }
      header.site-header {
        padding: 24px 0;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        background: var(--bg);
        z-index: 10;
      }
      .site-header .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .brand {
        font-family: var(--mono);
        font-size: 18px;
        letter-spacing: 0.02em;
        color: var(--text-strong);
      }
      .brand::before {
        content: '◆ ';
        color: var(--accent);
      }
      .nav {
        display: flex;
        gap: 24px;
        font-family: var(--mono);
        font-size: 13px;
      }
      .nav a {
        color: var(--text-dim);
        border-bottom: none;
      }
      .nav a:hover { color: var(--accent); }
      @media (max-width: 600px) {
        .nav { display: none; }
      }
      section.hero {
        padding: 96px 0 56px;
      }
      h1 {
        font-size: clamp(36px, 6vw, 60px);
        font-weight: 700;
        line-height: 1.05;
        letter-spacing: -0.02em;
        margin-bottom: 28px;
        color: var(--text-strong);
      }
      .hero p.tagline {
        font-size: 22px;
        color: var(--text);
        max-width: 680px;
        margin-bottom: 22px;
        line-height: 1.4;
      }
      .hero p.subline {
        font-size: 17px;
        color: var(--text-dim);
        max-width: 680px;
      }
      .hero-meta {
        margin-top: 32px;
        display: flex;
        gap: 28px;
        flex-wrap: wrap;
        font-family: var(--mono);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-dim);
      }
      .hero-meta .label { color: var(--accent); margin-right: 8px; }
      section {
        padding: 64px 0;
        border-top: 1px solid var(--border);
      }
      h2 {
        font-size: 13px;
        font-family: var(--mono);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
        margin-bottom: 24px;
        font-weight: 500;
      }
      h3 {
        font-size: 26px;
        font-weight: 600;
        margin-bottom: 18px;
        letter-spacing: -0.01em;
        color: var(--text-strong);
        line-height: 1.3;
      }
      h4 {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 10px;
        color: var(--text-strong);
      }
      p { margin-bottom: 18px; color: var(--text); }
      p.dim { color: var(--text-dim); }
      strong { color: var(--text-strong); font-weight: 600; }

      blockquote.pullquote {
        border-left: 3px solid var(--accent);
        padding: 12px 0 12px 24px;
        margin: 28px 0;
        font-size: 19px;
        color: var(--text);
        font-style: italic;
        line-height: 1.5;
      }
      blockquote.pullquote .attribution {
        display: block;
        margin-top: 10px;
        font-style: normal;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .sim-frame {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 14px;
        margin: 28px 0;
      }
      .sim-frame img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 4px;
      }
      .sim-caption {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--text-dim);
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
      }

      ul.feature-list {
        list-style: none;
        margin: 24px 0;
      }
      ul.feature-list li {
        padding: 14px 0;
        border-bottom: 1px solid var(--border);
        display: flex;
        gap: 18px;
        align-items: baseline;
      }
      ul.feature-list li:last-child { border-bottom: none; }
      ul.feature-list .key {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--accent);
        min-width: 160px;
        flex-shrink: 0;
      }
      ul.feature-list .val { color: var(--text); }

      .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 16px;
        margin: 28px 0;
      }
      .stat {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 22px 20px;
      }
      .stat .value {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-strong);
        line-height: 1;
        margin-bottom: 8px;
        letter-spacing: -0.01em;
      }
      .stat .label {
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-dim);
      }
      .stat .footnote {
        margin-top: 8px;
        font-size: 12px;
        color: var(--text-dim);
        font-family: var(--mono);
      }

      table.compare {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
        font-size: 14px;
      }
      table.compare th,
      table.compare td {
        text-align: left;
        padding: 12px 12px;
        border-bottom: 1px solid var(--border);
      }
      table.compare th {
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accent);
        font-weight: 500;
        background: var(--accent-soft);
      }
      table.compare td.headline {
        font-family: var(--mono);
        color: var(--text-strong);
        white-space: nowrap;
      }
      table.compare tr.skydock-row {
        background: rgba(96, 165, 250, 0.06);
      }
      table.compare tr.skydock-row td.headline {
        color: var(--accent);
      }

      ul.checklist {
        list-style: none;
        margin: 18px 0 24px;
      }
      ul.checklist li {
        padding: 8px 0 8px 28px;
        position: relative;
        color: var(--text);
      }
      ul.checklist li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--good);
        font-weight: 600;
      }

      .milestones {
        margin: 24px 0;
        border-left: 2px solid var(--border);
        padding-left: 20px;
      }
      .milestone {
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
      }
      .milestone:last-child { border-bottom: none; }
      .milestone .when {
        font-family: var(--mono);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accent);
        margin-bottom: 4px;
      }
      .milestone .what {
        color: var(--text-strong);
        font-weight: 500;
        margin-bottom: 4px;
      }
      .milestone .detail {
        font-size: 14px;
        color: var(--text-dim);
      }

      .contact-card {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 30px;
        margin: 24px 0;
      }
      .contact-card .name {
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 4px;
        color: var(--text-strong);
      }
      .contact-card .role {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--text-dim);
        margin-bottom: 18px;
      }
      .contact-card .bio { font-size: 16px; color: var(--text-dim); margin-bottom: 22px; }
      .contact-links { display: flex; gap: 24px; font-family: var(--mono); font-size: 14px; }

      .cta-row {
        display: flex;
        gap: 14px;
        margin-top: 28px;
        flex-wrap: wrap;
      }
      .cta {
        display: inline-block;
        padding: 14px 22px;
        border-radius: 6px;
        font-family: var(--mono);
        font-size: 14px;
        font-weight: 500;
        border-bottom: none;
      }
      .cta.primary {
        background: var(--accent);
        color: #0a0e1a;
      }
      .cta.primary:hover {
        background: #7ab1f5;
        border-bottom: none;
      }
      .cta.secondary {
        background: transparent;
        color: var(--accent);
        border: 1px solid var(--accent);
      }
      .cta.secondary:hover {
        background: var(--accent-soft);
        border-bottom: 1px solid var(--accent);
      }

      footer {
        padding: 48px 0;
        border-top: 1px solid var(--border);
        text-align: center;
        color: var(--text-dim);
        font-family: var(--mono);
        font-size: 12px;
      }

      @media (max-width: 600px) {
        body { font-size: 16px; }
        section.hero { padding: 64px 0 40px; }
        ul.feature-list li { flex-direction: column; gap: 4px; }
        ul.feature-list .key { min-width: 0; }
        table.compare { font-size: 13px; }
        table.compare th, table.compare td { padding: 10px 8px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container row">
        <span class="brand">skydock</span>
        <nav class="nav">
          <a href="#gap">The gap</a>
          <a href="#how">How it works</a>
          <a href="#why-now">Why now</a>
          <a href="#economics">Economics</a>
          <a href="#raise">The raise</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container">
          <h1>Aerial ground-truth for autonomous vehicles.</h1>
          <p class="tagline">{tagline}</p>
          <p class="subline">{subline}</p>
          <div class="hero-meta">
            <span><span class="label">stage</span>pre-seed</span>
            <span><span class="label">raising</span>$1.7M</span>
            <span><span class="label">target</span>CFP at month 15-18</span>
            <span><span class="label">based</span>Mountain View, CA</span>
          </div>
        </div>
      </section>

      <section id="gap">
        <div class="container">
          <h2>The gap</h2>
          <h3>A category nobody can collect at scale.</h3>
          <p>
            AV development teams have spent the last decade collecting
            ground-perspective training data &mdash; cameras and lidar on test
            vehicles, augmented with synthetic data generated from 3D scenes.
            <strong>Aerial bird's-eye-view footage &mdash; drone perspective
            from 80m AGL &mdash; has been a structurally missing category</strong>
            because the operational model didn't exist.
          </p>
          <p>
            Fixed-base drone-in-a-box systems (DJI Dock 2, Skydio Dock 2) only
            capture at the location they're installed. Manually-piloted drone
            collection caps at 2-4 captures per day per crew and costs $1,000+
            per usable clip. Synthetic BEV is strong on volume but acknowledged
            by AV teams to underperform real data on edge cases.
          </p>
          <blockquote class="pullquote">
            "Aerial BEV was the perspective we'd been trying to source
            internally for two years. The operational model just didn't exist
            at the scale we needed."
            <span class="attribution">— Head of Scenario Engineering, Tier-1 AV validation platform</span>
          </blockquote>
          <p class="dim">
            In customer-discovery conversations with eight AV engineering leads
            in early 2026, seven of eight confirmed the gap. Six confirmed
            pricing tolerance at $200+ per scenario. Four expressed commit-intent
            for a paid pilot subject to quality evidence.
          </p>
        </div>
      </section>

      <section id="how">
        <div class="container">
          <h2>The wedge</h2>
          <h3>The first vehicle-deployed aerial drone platform for AV data.</h3>
          <p>
            Skydock automates the operational layer. A roof-mounted dock
            containing sub-250g drones deploys autonomously at pre-planned
            waypoints or operator command, captures 30-120 seconds of BEV
            footage at 80m AGL above the scene, returns to the dock, and the
            resulting OpenSCENARIO 2.0 package is delivered to the customer
            within four hours.
          </p>
          <ul class="feature-list">
            <li>
              <span class="key">capture_layer</span>
              <span class="val">Roof-mounted dock houses three DJI Mini 4 Pro drones (249g, sub-FAA Remote ID exemption). One active, two on rotation between charge and standby.</span>
            </li>
            <li>
              <span class="key">trigger_modes</span>
              <span class="val">Pre-planned waypoint, operator manual button, or hard-brake event. Vehicle stationary during capture per FAA Part 107 VLOS.</span>
            </li>
            <li>
              <span class="key">mission_cycle</span>
              <span class="val">Pre-flight check 2s · launch 4s · climb to 80m AGL 18-25s · capture 30-120s · return 18-25s · BLE precision land 8s.</span>
            </li>
            <li>
              <span class="key">deliverable</span>
              <span class="val">OpenSCENARIO 2.0 + per-frame agent tracks (vehicles, pedestrians, cyclists) + camera-calibrated metadata + optional 4K H.265 raw. Drops into customer pipelines without schema rewrite.</span>
            </li>
            <li>
              <span class="key">target_cadence</span>
              <span class="val">20 captures per vehicle-day at 90%+ mission success rate. Six-vehicle Bay Area fleet → ~1,500 delivered scenarios per month.</span>
            </li>
          </ul>
        </div>
      </section>

      <section id="demo">
        <div class="container">
          <h2>Live simulation</h2>
          <h3>Every quantitative claim is grounded in this sim.</h3>
          <p class="dim">
            The repo backing this page is a 7,000-line physical-layer simulation
            covering flight dynamics, dock latch geometry, scene visibility,
            data pipeline latency, and unit economics. Capture rate, success
            rate, dock latch probability, and pricing are all sim-grounded &mdash;
            not spreadsheet estimates. The clip below renders one vehicle
            cycling through a mission with full deliverable emission.
          </p>
          <div class="sim-frame">
            <img src={`${import.meta.env.BASE_URL}/sim_demo.gif`} alt="Skydock cinematic simulation: host vehicle driving along an urban corridor, drone visibly launching from the vehicle, climbing to capture altitude, scanning a scene with agents in view, then returning and landing back on the vehicle" />
            <div class="sim-caption">
              1 host vehicle · urban_dense corridor · seed 11 · running event log: trigger → capture → delivered scenario
            </div>
          </div>
          <p class="dim">
            The same sim drives the Monte Carlo + sensitivity report that
            backs the unit-economics numbers below.
          </p>
        </div>
      </section>

      <section id="competitive">
        <div class="container">
          <h2>The landscape</h2>
          <h3>Why nobody has captured aerial BEV at scale.</h3>
          <p>
            Each existing alternative fails on a different axis. The integrated
            vehicle-deployed system is the wedge nobody has built.
          </p>
          <table class="compare">
            <thead>
              <tr>
                <th>Approach</th>
                <th>Limitation</th>
                <th>Per-scenario cost</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="headline">Fixed-base drone box</td>
                <td>One location per install. Useful for industrial inspection, not road scenarios.</td>
                <td>$15K+ install</td>
              </tr>
              <tr>
                <td class="headline">Manual drone collection</td>
                <td>Capacity caps at 2-4/day per crew. Operational overhead unsustainable.</td>
                <td>$1,000+</td>
              </tr>
              <tr>
                <td class="headline">Synthetic BEV</td>
                <td>Strong on volume, weaker on edge-case fidelity. Used <em>alongside</em> real data, not in place of it.</td>
                <td>$50-$300</td>
              </tr>
              <tr>
                <td class="headline">Public footage scrape</td>
                <td>Quality + legal issues. Three of eight customers tried; none reported it working.</td>
                <td>$0-low</td>
              </tr>
              <tr class="skydock-row">
                <td class="headline">Skydock</td>
                <td>Vehicle-deployed autonomous capture. Goes where the AV fleet goes. 20 captures/day per vehicle.</td>
                <td>$339 mid</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section id="why-now">
        <div class="container">
          <h2>Why now</h2>
          <h3>Three converging timing pressures.</h3>
          <ul class="checklist">
            <li>
              <strong>NHTSA scenario-based testing rules.</strong> The
              December 2024 NPRM shifts AV safety validation from
              miles-driven to scenario-coverage. Scenario libraries
              become regulatory infrastructure &mdash; the libraries
              need to be filled.
            </li>
            <li>
              <strong>Validation platforms commercializing.</strong>
              Applied Intuition's ScenarioLib launched in 2024,
              Foretellix has growing OEM partnerships, Parallel Domain
              is mid-pipeline on Series C. Scenario procurement is
              moving from research budget to product budget.
            </li>
            <li>
              <strong>First-mover infrastructure lock-in.</strong> Once
              Skydock data is in a customer's pipeline (file format,
              QA workflow, billing integration), switching cost is
              real. We estimate a 12-18 month window before a competitor
              with similar capital can ship a comparable system.
            </li>
          </ul>
          <p class="dim">
            As of mid-2026 we have not seen a single competing
            aerial-BEV vehicle-deployed product launch announcement.
            The category window is open.
          </p>
        </div>
      </section>

      <section id="customers">
        <div class="container">
          <h2>The customers</h2>
          <h3>Who buys, and what they look like.</h3>
          <p>
            The buyer is a Head of Scenario Engineering (or Head of
            Simulation, or VP of Engineering at smaller validation
            shops) &mdash; typically a former AV research lead with a
            $100K-$1M/year data-acquisition budget. Technical buyer
            first, procurement second.
          </p>
          <p>
            The pre-seed-to-CFP customer set is the validation-platform
            and synthetic-data cohort. Tier-1 AV companies and OEMs are
            the seed/Series-A growth thesis, not the pre-seed thesis.
          </p>
          <ul class="feature-list">
            <li>
              <span class="key">validation platforms</span>
              <span class="val">Applied Intuition, Foretellix, Parallel Domain, Cognata — buy scenarios for their library products. 100-500 scenarios per pilot, $30K-$150K. Year-1 target.</span>
            </li>
            <li>
              <span class="key">tier-1 AV co's</span>
              <span class="val">Waymo, Aurora, Pony.ai, Zoox — long sales cycle, large deals. 1000+ scenarios, $100K-$500K. Year-2 onward.</span>
            </li>
            <li>
              <span class="key">automakers</span>
              <span class="val">GM, Ford, Toyota, Mercedes — slowest sales cycle, largest deals. 5K+ scenarios, $500K-$2M. Year-3 onward.</span>
            </li>
          </ul>
        </div>
      </section>

      <section id="economics">
        <div class="container">
          <h2>Unit economics</h2>
          <h3>Sim-grounded numbers, not spreadsheet estimates.</h3>
          <p class="dim">
            Pricing is derived bottoms-up from the customer's cost-to-replicate
            (in-house operator labor + annotation + amortized capex) plus a
            documented vendor markup band. Mid-case lands at $339 per scenario;
            range $136-$632 depending on customer tier and edge-case premium.
          </p>
          <div class="stat-grid">
            <div class="stat">
              <div class="value">$339</div>
              <div class="label">mid-case ASP per scenario</div>
              <div class="footnote">range $136 - $632</div>
            </div>
            <div class="stat">
              <div class="value">94%</div>
              <div class="label">contribution margin per scenario</div>
              <div class="footnote">var cost ~$19/scenario</div>
            </div>
            <div class="stat">
              <div class="value">$1.4M</div>
              <div class="label">LTV per vehicle over 24 mo</div>
              <div class="footnote">at mid-case ASP + delivery rate</div>
            </div>
            <div class="stat">
              <div class="value">65%</div>
              <div class="label">gross margin at steady state</div>
              <div class="footnote">includes opex + overhead</div>
            </div>
            <div class="stat">
              <div class="value">~$640K</div>
              <div class="label">monthly revenue at 6-vehicle scale</div>
              <div class="footnote">sim-derived mid-case</div>
            </div>
            <div class="stat">
              <div class="value">M15-18</div>
              <div class="label">cash-flow positive milestone</div>
              <div class="footnote">on $1.7M pre-seed</div>
            </div>
          </div>
          <p class="dim">
            Sensitivity testing across delivery rate, ASP, and weather
            envelope yields three scenarios: pessimistic ($150 ASP,
            slip to month 22, buffer drawdown), mid-case ($339 ASP,
            CFP month 15, buffer preserved), optimistic ($500 ASP,
            CFP month 11, expansion-ready without seed dependency).
          </p>
        </div>
      </section>

      <section id="raise">
        <div class="container">
          <h2>The raise</h2>
          <h3>$1.7M pre-seed, 18 months to cash-flow positive.</h3>
          <p>
            The raise funds the negative-cash window: MVP build (months 1-6),
            first paid pilots (months 7-12), and fleet ramp to six vehicles
            (months 13-18). Beyond month 18 the business is self-funding;
            the seed round, if raised, is for multi-market expansion, not
            survival.
          </p>
          <div class="milestones">
            <div class="milestone">
              <div class="when">M0 · pre-seed close</div>
              <div class="what">$1.7M committed; founder + hardware contractor onboarded.</div>
            </div>
            <div class="milestone">
              <div class="when">M4 · first MVP capture</div>
              <div class="what">One vehicle operational; first scenario package emitted.</div>
              <div class="detail">Reviewed by ≥3 prospect customers for quality + format fit.</div>
            </div>
            <div class="milestone">
