---
const tagline = "Aerial BEV training data for AV scenario libraries — delivered in OpenSCENARIO 2.0, captured by drones deployed from moving fleet vehicles.";
const subline = "Skydock fills the aerial-perspective slot in your scenario library at the locations your fleet actually operates. Drops into your existing pipeline without schema rewrite, naming-convention negotiation, or QA process changes.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={tagline} />
    <meta property="og:title" content="Skydock — Aerial BEV scenarios for AV training" />
    <meta property="og:description" content={tagline} />
    <meta property="og:type" content="website" />
    <title>Skydock — Aerial BEV scenarios for AV training</title>
    <style is:global>
      :root {
        --bg: #0a0e1a;
        --bg-elev: #111827;
        --border: #1f2937;
        --text: #e5e7eb;
        --text-dim: #9ca3af;
        --text-strong: #f9fafb;
        --accent: #60a5fa;
        --accent-dim: #1e3a8a;
        --accent-soft: rgba(96, 165, 250, 0.08);
        --good: #9ee37d;
        --warn: #e5b85a;
        --mono: 'SF Mono', 'Monaco', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
        --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        line-height: 1.65;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.15s ease;
      }
      a:hover { border-bottom-color: var(--accent); }
      .container {
        max-width: 820px;
        margin: 0 auto;
        padding: 0 24px;
      }
      header.site-header {
        padding: 24px 0;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        background: var(--bg);
        z-index: 10;
      }
      .site-header .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .brand {
        font-family: var(--mono);
        font-size: 18px;
        letter-spacing: 0.02em;
        color: var(--text-strong);
      }
      .brand::before {
        content: '◆ ';
        color: var(--accent);
      }
      .nav {
        display: flex;
        gap: 24px;
        font-family: var(--mono);
        font-size: 13px;
      }
      .nav a {
        color: var(--text-dim);
        border-bottom: none;
      }
      .nav a:hover { color: var(--accent); }
      @media (max-width: 600px) {
        .nav { display: none; }
      }
      section.hero { padding: 96px 0 56px; }
      h1 {
        font-size: clamp(36px, 6vw, 60px);
        font-weight: 700;
        line-height: 1.05;
        letter-spacing: -0.02em;
        margin-bottom: 28px;
        color: var(--text-strong);
      }
      .hero p.tagline {
        font-size: 22px;
        color: var(--text);
        max-width: 680px;
        margin-bottom: 22px;
        line-height: 1.4;
      }
      .hero p.subline {
        font-size: 17px;
        color: var(--text-dim);
        max-width: 680px;
      }
      .hero-meta {
        margin-top: 32px;
        display: flex;
        gap: 28px;
        flex-wrap: wrap;
        font-family: var(--mono);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-dim);
      }
      .hero-meta .label { color: var(--accent); margin-right: 8px; }
      section {
        padding: 64px 0;
        border-top: 1px solid var(--border);
      }
      h2 {
        font-size: 13px;
        font-family: var(--mono);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
        margin-bottom: 24px;
        font-weight: 500;
      }
      h3 {
        font-size: 26px;
        font-weight: 600;
        margin-bottom: 18px;
        letter-spacing: -0.01em;
        color: var(--text-strong);
        line-height: 1.3;
      }
      h4 {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 10px;
        color: var(--text-strong);
      }
      p { margin-bottom: 18px; color: var(--text); }
      p.dim { color: var(--text-dim); }
      strong { color: var(--text-strong); font-weight: 600; }

      blockquote.pullquote {
        border-left: 3px solid var(--accent);
        padding: 12px 0 12px 24px;
        margin: 28px 0;
        font-size: 19px;
        color: var(--text);
        font-style: italic;
        line-height: 1.5;
      }
      blockquote.pullquote .attribution {
        display: block;
        margin-top: 10px;
        font-style: normal;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .sim-frame {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 14px;
        margin: 28px 0;
      }
      .sim-frame img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 4px;
      }
      .sim-caption {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--text-dim);
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
      }

      ul.feature-list {
        list-style: none;
        margin: 24px 0;
      }
      ul.feature-list li {
        padding: 14px 0;
        border-bottom: 1px solid var(--border);
        display: flex;
        gap: 18px;
        align-items: baseline;
      }
      ul.feature-list li:last-child { border-bottom: none; }
      ul.feature-list .key {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--accent);
        min-width: 170px;
        flex-shrink: 0;
      }
      ul.feature-list .val { color: var(--text); }

      .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
        margin: 28px 0;
      }
      .stat {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 22px 20px;
      }
      .stat .value {
        font-size: 26px;
        font-weight: 700;
        color: var(--text-strong);
        line-height: 1;
        margin-bottom: 8px;
        letter-spacing: -0.01em;
      }
      .stat .label {
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-dim);
      }
      .stat .footnote {
        margin-top: 8px;
        font-size: 12px;
        color: var(--text-dim);
        font-family: var(--mono);
      }

      table.compare {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
        font-size: 14px;
      }
      table.compare th,
      table.compare td {
        text-align: left;
        padding: 12px 12px;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }
      table.compare th {
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accent);
        font-weight: 500;
        background: var(--accent-soft);
      }
      table.compare td.headline {
        font-family: var(--mono);
        color: var(--text-strong);
        white-space: nowrap;
      }
      table.compare tr.skydock-row {
        background: rgba(96, 165, 250, 0.06);
      }
      table.compare tr.skydock-row td.headline { color: var(--accent); }

      table.pricing {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
        font-size: 15px;
      }
      table.pricing th,
      table.pricing td {
        text-align: left;
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
      }
      table.pricing th {
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-dim);
        font-weight: 500;
      }
      table.pricing td.tier {
        font-family: var(--mono);
        color: var(--text-strong);
      }
      table.pricing td.price {
        font-family: var(--mono);
        color: var(--accent);
        font-weight: 600;
        white-space: nowrap;
      }

      .deliverable-card {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 22px;
        margin: 24px 0;
        font-family: var(--mono);
        font-size: 13.5px;
        line-height: 1.7;
      }
      .deliverable-card .tree-line { color: var(--text-dim); }
      .deliverable-card .file { color: var(--accent); }
      .deliverable-card .desc { color: var(--text-dim); }

      .scene-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
        margin: 24px 0;
      }
      .scene-tag {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 12px 14px;
      }
      .scene-tag .name {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--accent);
        margin-bottom: 4px;
      }
      .scene-tag .desc {
        font-size: 13px;
        color: var(--text-dim);
        line-height: 1.4;
      }

      ul.sla-list { list-style: none; margin: 18px 0 24px; }
      ul.sla-list li {
        padding: 10px 0 10px 30px;
        position: relative;
        color: var(--text);
        border-bottom: 1px solid var(--border);
      }
      ul.sla-list li:last-child { border-bottom: none; }
      ul.sla-list li::before {
        content: "✓";
        position: absolute;
        left: 0;
        top: 10px;
        color: var(--good);
        font-weight: 600;
      }
      ul.sla-list .pct {
        font-family: var(--mono);
        color: var(--accent);
        font-weight: 600;
      }

      .contact-card {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 30px;
        margin: 24px 0;
      }
      .contact-card .name {
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 4px;
        color: var(--text-strong);
      }
      .contact-card .role {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--text-dim);
        margin-bottom: 18px;
      }
      .contact-card .bio { font-size: 16px; color: var(--text-dim); margin-bottom: 22px; }
      .contact-links { display: flex; gap: 24px; font-family: var(--mono); font-size: 14px; }

      .cta-row {
        display: flex;
        gap: 14px;
        margin-top: 28px;
        flex-wrap: wrap;
      }
      .cta {
        display: inline-block;
        padding: 14px 22px;
        border-radius: 6px;
        font-family: var(--mono);
        font-size: 14px;
        font-weight: 500;
        border-bottom: none;
      }
      .cta.primary { background: var(--accent); color: #0a0e1a; }
      .cta.primary:hover { background: #7ab1f5; border-bottom: none; }
      .cta.secondary {
        background: transparent;
        color: var(--accent);
        border: 1px solid var(--accent);
      }
      .cta.secondary:hover {
        background: var(--accent-soft);
        border-bottom: 1px solid var(--accent);
      }

      footer {
        padding: 48px 0;
        border-top: 1px solid var(--border);
        text-align: center;
        color: var(--text-dim);
        font-family: var(--mono);
        font-size: 12px;
      }

      @media (max-width: 600px) {
        body { font-size: 16px; }
        section.hero { padding: 64px 0 40px; }
        ul.feature-list li { flex-direction: column; gap: 4px; }
        ul.feature-list .key { min-width: 0; }
        table.compare, table.pricing { font-size: 13px; }
        table.compare th, table.compare td,
        table.pricing th, table.pricing td { padding: 10px 8px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container row">
        <span class="brand">skydock</span>
        <nav class="nav">
          <a href="#scenario">What you get</a>
          <a href="#capture">How it works</a>
          <a href="#scenes">Scene classes</a>
          <a href="#fleet">Our fleet</a>
          <a href="#pricing">Pricing</a>
          <a href="#pilot">Start a pilot</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container">
          <h1>Aerial BEV scenarios for AV training, on demand.</h1>
          <p class="tagline">{tagline}</p>
          <p class="subline">{subline}</p>
          <div class="hero-meta">
            <span><span class="label">delivery</span>4 hr SLA</span>
            <span><span class="label">format</span>OpenSCENARIO 2.0</span>
            <span><span class="label">starting</span>$339/scenario</span>
            <span><span class="label">pilot</span>from 100 scenarios</span>
          </div>
        </div>
      </section>

      <section id="scenario">
        <div class="container">
          <h2>What you get</h2>
          <h3>A scenario package that drops into your pipeline.</h3>
          <p>
            Every Skydock scenario is a 30-120 second aerial bird's-eye-view
            recording captured from 80m AGL, delivered as a four-file package
            named by scenario ID. No proprietary schemas, no custom ingestion.
          </p>
          <div class="deliverable-card">
            <span class="tree-line">scenario_skydock-mission-00042/</span><br>
            <span class="tree-line">├─</span> <span class="file">metadata.json</span>           <span class="desc">scene class · GPS with uncertainty · capture geometry · DJI Mini 4 Pro calibration · quality score with methodology</span><br>
            <span class="tree-line">├─</span> <span class="file">agent_tracks.json</span>       <span class="desc">per-frame ENU positions of every visible vehicle / pedestrian / cyclist at 30 fps, with heading and speed</span><br>
            <span class="tree-line">├─</span> <span class="file">scenario.xosc</span>           <span class="desc">OpenSCENARIO 2.0 export — road network reference, scenario entities, storyboard skeleton</span><br>
            <span class="tree-line">└─</span> <span class="file">raw_video.mp4</span>           <span class="desc">optional 4K H.265 source video — request at scenario commission time</span>
          </div>
          <p class="dim">
            File sizes: metadata ~2 KB · agent_tracks 50-500 KB depending on
            agent count · OpenSCENARIO ~5 KB · raw 4K video 200-600 MB.
            Sample package available on request.
          </p>
        </div>
      </section>

      <section id="capture">
        <div class="container">
          <h2>How it works</h2>
          <h3>Vehicle arrives at waypoint → drone captures → package delivered in 4 hours.</h3>
          <p>
            When a Skydock-equipped vehicle reaches a pre-planned waypoint, or
            the operator triggers manually, the system runs a 2-second pre-flight
            check, deploys a sub-250g drone, climbs to 80m AGL, captures, and
            returns. Total mission time: ~90 seconds. The vehicle is stationary
            throughout per FAA Part 107 VLOS.
          </p>
          <ul class="feature-list">
            <li>
              <span class="key">trigger</span>
              <span class="val">Pre-planned waypoint, operator manual button, or hard-brake event. Custom waypoints (specific intersections, times of day, conditions) can be added to the operator's route.</span>
            </li>
            <li>
              <span class="key">capture geometry</span>
              <span class="val">80m AGL · 80° diagonal FOV · ~67m footprint radius — captures a full signalized intersection or a 130m corridor in a single frame.</span>
            </li>
            <li>
              <span class="key">capture duration</span>
              <span class="val">30-120s per scenario, operator-configurable. Default 60s for intersection scenarios, 30s for crosswalks, 120s for arterial corridors.</span>
            </li>
            <li>
              <span class="key">processing</span>
              <span class="val">Cloud pipeline: upload → BEV transform → YOLOv8 + ByteTrack agent detection → OpenSCENARIO export → quality scoring → delivery.</span>
            </li>
            <li>
              <span class="key">delivery</span>
              <span class="val">S3 pre-signed URL within 4 hours of capture. Optional SFTP, custom S3 bucket, or streaming API endpoint for enterprise customers.</span>
            </li>
          </ul>
        </div>
      </section>

      <section id="demo">
        <div class="container">
          <h2>Live simulation</h2>
          <h3>See the mission cycle.</h3>
          <p class="dim">
            One vehicle, one mission cycle: trigger fires, drone deploys,
            climbs to 80m, captures the scene with agents in the FOV, returns
            and lands. The same simulation that backs our delivery rate,
            success rate, and quality methodology numbers.
          </p>
          <div class="sim-frame">
            <img src={`${import.meta.env.BASE_URL}/sim_demo.gif`} alt="Skydock simulation: host vehicle driving along an urban corridor, drone visibly launching from the vehicle, climbing to capture altitude, scanning a scene with agents in view, then returning and landing back on the vehicle" />
            <div class="sim-caption">
              urban_dense corridor · waypoint trigger · agents tracked in FOV · event log on right
            </div>
          </div>
        </div>
      </section>

      <section id="scenes">
        <div class="container">
          <h2>Scene classes</h2>
          <h3>What we capture, out of the box.</h3>
          <p>
            Ten built-in scene classes drawn from common AV validation
            taxonomies. Custom taxonomies (your internal scene-class
            definitions) onboarded in ~1 week.
          </p>
          <div class="scene-grid">
            <div class="scene-tag">
              <div class="name">intersection_signalized</div>
              <div class="desc">Full 4-way signalized intersection with signal cycle phasing.</div>
            </div>
            <div class="scene-tag">
              <div class="name">intersection_unsignalized</div>
              <div class="desc">Stop-controlled or yield intersections.</div>
            </div>
            <div class="scene-tag">
              <div class="name">unprotected_left_turn</div>
              <div class="desc">Left turn across oncoming traffic. High-priority for AV validation.</div>
            </div>
            <div class="scene-tag">
              <div class="name">pedestrian_crosswalk</div>
              <div class="desc">Mid-block crosswalks with VRU interactions.</div>
            </div>
            <div class="scene-tag">
              <div class="name">vru_interaction</div>
              <div class="desc">Mixed-mode vehicles, pedestrians, cyclists in close proximity.</div>
            </div>
            <div class="scene-tag">
              <div class="name">school_zone</div>
              <div class="desc">School zones with crossing guard, bus, children.</div>
            </div>
            <div class="scene-tag">
              <div class="name">construction_zone</div>
              <div class="desc">Work zones with lane modifications, cones, workers.</div>
            </div>
            <div class="scene-tag">
              <div class="name">merge_arterial</div>
              <div class="desc">Arterial merge points with moderate-speed traffic.</div>
            </div>
            <div class="scene-tag">
              <div class="name">merge_highway</div>
              <div class="desc">Highway entrance/exit ramps with high-speed merge dynamics.</div>
            </div>
            <div class="scene-tag">
              <div class="name">lane_change_complex</div>
              <div class="desc">Multi-vehicle lane change scenarios on multi-lane arterials.</div>
            </div>
          </div>
          <p class="dim">
            Custom scenarios &mdash; specific intersections, specific times
            of day, specific weather conditions if reproducible &mdash;
            priced 2-3&times; standard tier.
          </p>
        </div>
      </section>

      <section id="quality">
        <div class="container">
          <h2>Quality methodology</h2>
          <h3>Every scenario carries a transparent 0-100 score.</h3>
          <p>
            Quality is computed from agent visibility, not drawn from a
            distribution. Every scenario's <code>metadata.json</code>
            includes the exact methodology so your QA team can verify the
            score against the agent tracks.
          </p>
          <ul class="feature-list">
            <li>
              <span class="key">60 points</span>
              <span class="val">Agent visibility ratio — frames each agent was inside the drone's FOV / total frames observed.</span>
            </li>
            <li>
              <span class="key">20 points</span>
              <span class="val">Agent coverage — saturated at 70% of spawned agents to reflect realistic FOV limits.</span>
            </li>
            <li>
              <span class="key">20 points</span>
              <span class="val">Agent class diversity — vehicle / pedestrian / cyclist representation.</span>
            </li>
            <li>
              <span class="key">multipliers</span>
              <span class="val">Altitude-resolution factor (1.0 at 80m AGL, decreasing above). Wind-shake factor (1.0 at ≤12 mph, decreasing above, 10% floor).</span>
            </li>
          </ul>
          <p>
            <strong>Scenarios scoring below 70 are not delivered.</strong> No
            charge, no opt-in. If we can't hit the bar, we don't ship.
          </p>
        </div>
      </section>

      <section id="pricing">
        <div class="container">
          <h2>Pricing</h2>
          <h3>Volume-tiered. No long contracts to start.</h3>
          <p>
            Pricing is derived bottoms-up from your cost-to-replicate
            (in-house operator labor + annotation + amortized capex) plus a
            documented vendor markup band. The full methodology is in our
            FAQ; the resulting tiers are below.
          </p>
          <table class="pricing">
            <thead>
              <tr>
                <th>Tier</th>
                <th>Scenarios</th>
                <th>Per scenario</th>
                <th>Premium edge case</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="tier">Pilot</td>
                <td>1 – 99</td>
                <td class="price">$339</td>
                <td>$632</td>
              </tr>
              <tr>
                <td class="tier">Volume 1</td>
                <td>100 – 499</td>
                <td class="price">$200</td>
                <td>$400</td>
              </tr>
              <tr>
                <td class="tier">Volume 2</td>
                <td>500 – 999</td>
                <td class="price">$150</td>
                <td>$300</td>
              </tr>
              <tr>
                <td class="tier">Volume 3</td>
                <td>1,000+</td>
                <td class="price">$100</td>
                <td>$200</td>
              </tr>
              <tr>
                <td class="tier">Enterprise</td>
                <td>Custom</td>
                <td class="price">contact us</td>
                <td>custom</td>
              </tr>
            </tbody>
          </table>
          <p class="dim">
            Minimum pilot commitment: $25K (~74 scenarios at pilot rate).
            Custom scenario taxonomies onboarded at $5K-$15K depending on
            schema complexity. Bulk corpus access (historical scenarios)
            quoted separately.
          </p>
        </div>
      </section>

      <section id="sla">
        <div class="container">
          <h2>SLA</h2>
          <h3>What we commit to, and what happens when we miss.</h3>
          <ul class="sla-list">
            <li>
