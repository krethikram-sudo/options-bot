venv/
__pycache__/
*.pyc
.env
.DS_Store
data_cache/
backtest_results/
*.log

# Per-user runtime state — trading history, positions, alerts
logs/*
!logs/.gitkeep

# Bulk historical price data (re-fetchable via research/build_dataset_extended.py)
research/data/
research/data_extended/
research/strategies/*.csv
research/strategies/*.parquet
research/strategies/iter_log.jsonl

# Rendered launchd plist (per-user)
launchd/*.plist
!launchd/*.plist.template

# Premium strategy files — distributed via private companion repo to subscribers.
# The empty premium/ dir + its README + __init__.py stay tracked.
premium/*.py
!premium/__init__.py

# ModelPilot gateway runtime state (savings ledger)
modelpilot*.db

# ModelPilot license signing key — never commit
license_private_key.pem
*license_private_key*.pem

# Built thin-client distribution (regenerate with scripts/build_client.sh)
dist/
