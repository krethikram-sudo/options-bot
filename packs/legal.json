    {"name": "redline", "any": ["redline", "mark up this clause", "revise this clause", "make this mutual", "suggest edits to this clause"], "category": "rewrite_format", "max_tier": 1},
    {"name": "contract-summary", "any": ["summarize this contract", "summarize this agreement", "summarize this lease", "summarize this msa", "key terms of this"], "category": "summarization_long", "max_tier": 1}
  ],
  "profile": {"min_model": "claude-sonnet-4-6", "risk_tolerance": "balanced"}
